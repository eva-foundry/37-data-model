{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "L75 - work_factory_governance",
  "description": "Governance policies and compliance rules for the work factory. Defines policy rules, compliance requirements, approval thresholds, audit procedures, and enforcement mechanisms. Enables policy-driven governance, compliance auditing, and automated enforcement.",
  "type": "object",
  "required": [
    "id",
    "policy_name",
    "policy_type",
    "scope",
    "status",
    "effective_date",
    "owner_type",
    "owner_id"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Primary key: governance-policy-{name-slug}",
      "pattern": "^governance-policy-[a-z0-9-]+$",
      "examples": ["governance-policy-security-review-required", "governance-policy-cost-approval-threshold"]
    },
    "policy_name": {
      "type": "string",
      "description": "Human-readable policy name",
      "minLength": 3,
      "maxLength": 200,
      "examples": ["Security Review Required for Production Deployments", "Cost Approval Threshold Policy"]
    },
    "description": {
      "type": "string",
      "description": "Detailed policy description and rationale",
      "examples": ["All production deployments must undergo security review before approval to ensure compliance with organizational security standards"]
    },
    "policy_type": {
      "type": "string",
      "description": "Type of governance policy",
      "enum": [
        "approval_workflow",
        "compliance_requirement",
        "quality_gate",
        "cost_control",
        "security_control",
        "operational_standard",
        "slo_enforcement",
        "risk_management",
        "audit_rule"
      ]
    },
    "scope": {
      "type": "string",
      "description": "Scope of policy application",
      "enum": ["factory_wide", "portfolio", "service", "capability", "project"]
    },
    "portfolio_ids": {
      "type": "array",
      "description": "FK to L71 work_factory_portfolio.id (portfolios where this policy applies, if scope=portfolio)",
      "items": {
        "type": "string",
        "pattern": "^portfolio-[a-z0-9-]+$"
      }
    },
    "service_ids": {
      "type": "array",
      "description": "FK to L62 work_factory_services.id (services where this policy applies, if scope=service)",
      "items": {
        "type": "string",
        "pattern": "^service-[a-z0-9-]+$"
      }
    },
    "capability_ids": {
      "type": "array",
      "description": "FK to L61 work_factory_capabilities.id (capabilities where this policy applies, if scope=capability)",
      "items": {
        "type": "string",
        "pattern": "^capability-[a-z0-9-]+$"
      }
    },
    "status": {
      "type": "string",
      "description": "Policy lifecycle status",
      "enum": ["draft", "proposed", "active", "deprecated", "retired"]
    },
    "effective_date": {
      "type": "string",
      "format": "date",
      "description": "Date when policy becomes effective (YYYY-MM-DD)"
    },
    "expiration_date": {
      "type": "string",
      "format": "date",
      "description": "Date when policy expires or requires review (YYYY-MM-DD)"
    },
    "owner_type": {
      "type": "string",
      "description": "Type of entity that owns this policy",
      "enum": ["cp_agent", "human", "team", "department", "board"]
    },
    "owner_id": {
      "type": "string",
      "description": "Polymorphic FK to policy owner",
      "examples": ["cp-agent-eva-foundation", "team-security"]
    },
    "enforcement_mechanism": {
      "type": "string",
      "description": "How policy is enforced",
      "enum": [
        "automated_blocking",
        "automated_warning",
        "manual_review_required",
        "advisory_only",
        "audit_post_facto"
      ]
    },
    "policy_rules": {
      "type": "array",
      "description": "Detailed policy rules and conditions",
      "items": {
        "type": "object",
        "required": ["rule_id", "rule_description", "condition_type"],
        "properties": {
          "rule_id": {
            "type": "string",
            "description": "Unique rule identifier within policy",
            "examples": ["rule-01-threshold", "rule-02-approval"]
          },
          "rule_description": {
            "type": "string",
            "description": "Human-readable rule description"
          },
          "condition_type": {
            "type": "string",
            "description": "Type of condition",
            "enum": [
              "metric_threshold",
              "cost_threshold",
              "approval_required",
              "mandatory_step",
              "prohibited_action",
              "time_based",
              "risk_level"
            ]
          },
          "condition_details": {
            "type": "object",
            "description": "Condition-specific parameters",
            "properties": {
              "metric_name": {
                "type": "string",
                "description": "Metric being evaluated (for metric_threshold type)"
              },
              "operator": {
                "type": "string",
                "description": "Comparison operator",
                "enum": ["<", "<=", "=", ">=", ">", "!=", "in", "not_in"]
              },
              "threshold_value": {
                "type": "string",
                "description": "Threshold value (string to support various types)"
              },
              "required_approvers": {
                "type": "array",
                "description": "Required approvers (for approval_required type)",
                "items": {
                  "type": "string"
                }
              },
              "minimum_approvals_required": {
                "type": "integer",
                "description": "Minimum number of approvals required",
                "minimum": 1
              },
              "prohibited_actions": {
                "type": "array",
                "description": "Actions that are prohibited (for prohibited_action type)",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "enforcement_action": {
            "type": "string",
            "description": "Action to take when rule is violated",
            "enum": [
              "block_execution",
              "require_approval",
              "send_alert",
              "log_warning",
              "escalate",
              "trigger_audit"
            ]
          },
          "exemption_criteria": {
            "type": "string",
            "description": "Conditions under which exemptions are granted"
          }
        }
      }
    },
    "compliance_mappings": {
      "type": "array",
      "description": "Mapping to external compliance frameworks",
      "items": {
        "type": "object",
        "properties": {
          "framework_name": {
            "type": "string",
            "description": "Compliance framework name",
            "examples": ["ISO 27001", "SOC 2 Type II", "GDPR", "HIPAA"]
          },
          "control_id": {
            "type": "string",
            "description": "Control identifier in external framework",
            "examples": ["ISO-27001-A.12.1.2", "SOC2-CC6.1"]
          },
          "control_description": {
            "type": "string",
            "description": "Control description from framework"
          }
        }
      }
    },
    "related_cp_policy_ids": {
      "type": "array",
      "description": "FK to L16 cp_policies.id (related control plane policies)",
      "items": {
        "type": "string"
      }
    },
    "related_metric_ids": {
      "type": "array",
      "description": "FK to L74 work_factory_metrics.id (metrics used for policy enforcement)",
      "items": {
        "type": "string",
        "pattern": "^metric-[a-z0-9-]+-[a-z0-9-]+-[0-9]{8}-[0-9]{4}$"
      }
    },
    "violation_history": {
      "type": "object",
      "description": "Historical policy violations summary",
      "properties": {
        "total_violations_count": {
          "type": "integer",
          "description": "Total violations since policy effective date",
          "minimum": 0
        },
        "violations_last_30d": {
          "type": "integer",
          "description": "Violations in last 30 days",
          "minimum": 0
        },
        "last_violation_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of most recent violation"
        },
        "most_common_violation_reason": {
          "type": "string",
          "description": "Most common reason for violations"
        }
      }
    },
    "audit_trail": {
      "type": "array",
      "description": "Audit trail of policy changes and reviews",
      "items": {
        "type": "object",
        "properties": {
          "event_type": {
            "type": "string",
            "enum": ["created", "updated", "reviewed", "deprecated", "retired", "exemption_granted"]
          },
          "event_timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "When event occurred"
          },
          "event_actor": {
            "type": "string",
            "description": "Who performed the action"
          },
          "event_details": {
            "type": "string",
            "description": "Additional event details or justification"
          }
        }
      }
    },
    "evidence_ids": {
      "type": "array",
      "description": "FK to L31 evidence.id (policy documentation, approval records, audit reports)",
      "items": {
        "type": "string"
      }
    },
    "review_frequency": {
      "type": "string",
      "description": "Required review frequency for policy",
      "enum": ["monthly", "quarterly", "semi_annual", "annual", "ad_hoc"]
    },
    "last_reviewed_at": {
      "type": "string",
      "format": "date-time",
      "description": "When policy was last reviewed"
    },
    "next_review_due": {
      "type": "string",
      "format": "date",
      "description": "Next review due date (YYYY-MM-DD)"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Policy creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last updated timestamp"
    },
    "notes": {
      "type": "string",
      "description": "Additional context, rationale, or implementation notes"
    }
  },
  "additionalProperties": false
}
