{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "L68 - work_service_remediation_plans",
  "description": "Remediation plans for SLA breaches (L67) — step-by-step recovery procedures with resource estimates. Created automatically from runbooks or manually by operators. Feeds work execution units (L52) for automated remediation.",
  "required": [
    "id",
    "breach_id",
    "service_id",
    "plan_type",
    "status",
    "created_at",
    "created_by"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Primary key: remediation-{breach_id}",
      "pattern": "^remediation-breach-slo-service-[a-z0-9-]+-[a-z0-9_-]+-[0-9]{8}-[0-9]{2}$",
      "examples": ["remediation-breach-slo-service-schema-migrator-success_rate-20260309-01"]
    },
    "breach_id": {
      "type": "string",
      "description": "FK to L67 work_service_breaches (CASCADE on delete). Which breach this plan addresses.",
      "pattern": "^breach-slo-service-[a-z0-9-]+-[a-z0-9_-]+-[0-9]{8}-[0-9]{2}$"
    },
    "service_id": {
      "type": "string",
      "description": "FK to L62 work_factory_services (RESTRICT on delete). Service being remediated.",
      "pattern": "^service-[a-z0-9-]+$"
    },
    "plan_type": {
      "type": "string",
      "enum": ["automated", "semi_automated", "manual", "escalation"],
      "description": "Remediation approach: automated (fully automatic), semi_automated (requires approval), manual (human-driven), escalation (requires expert intervention)"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "approved", "executing", "completed", "failed", "cancelled"],
      "description": "Plan lifecycle status"
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"],
      "description": "Remediation priority (inherited from breach severity)"
    },
    "title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "Brief remediation plan title"
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "maxLength": 2000,
      "description": "Detailed plan description including expected outcomes"
    },
    "remediation_steps": {
      "type": "array",
      "description": "Ordered list of remediation steps",
      "items": {
        "type": "object",
        "required": ["step_number", "step_name", "step_description", "required"],
        "properties": {
          "step_number": {
            "type": "integer",
            "minimum": 1,
            "description": "Step sequence number"
          },
          "step_name": {
            "type": "string",
            "minLength": 3,
            "maxLength": 100,
            "description": "Short step name"
          },
          "step_description": {
            "type": "string",
            "minLength": 10,
            "maxLength": 1000,
            "description": "Detailed step instructions"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this step is mandatory or optional"
          },
          "estimated_duration_minutes": {
            "type": "integer",
            "minimum": 1,
            "description": "Estimated time to complete this step"
          },
          "automation_available": {
            "type": "boolean",
            "description": "Whether this step can be automated"
          },
          "validation_criteria": {
            "type": "array",
            "items": {"type": "string"},
            "description": "How to verify this step succeeded"
          },
          "rollback_instructions": {
            "type": "string",
            "description": "How to undo this step if needed"
          }
        }
      },
      "minItems": 1
    },
    "estimated_duration_minutes": {
      "type": "integer",
      "minimum": 1,
      "description": "Total estimated remediation time (sum of all step estimates)"
    },
    "resource_requirements": {
      "type": "object",
      "description": "Required resources for remediation execution",
      "properties": {
        "agent_type": {
          "type": "string",
          "description": "Type of agent needed (if automated/semi-automated)"
        },
        "human_expertise": {
          "type": "string",
          "description": "Required human skills (if manual/escalation)"
        },
        "infrastructure_changes": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Infrastructure modifications needed (scaling, config, etc.)"
        },
        "estimated_cost_usd": {
          "type": "number",
          "minimum": 0,
          "description": "Estimated cost of remediation"
        }
      }
    },
    "risks": {
      "type": "array",
      "description": "Known risks and mitigation strategies",
      "items": {
        "type": "object",
        "properties": {
          "risk_description": {"type": "string"},
          "likelihood": {"type": "string", "enum": ["low", "medium", "high"]},
          "mitigation": {"type": "string"}
        }
      }
    },
    "approved_by": {
      "type": ["string", "null"],
      "description": "Who approved this plan (required for semi_automated/manual/escalation)"
    },
    "approved_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "When plan was approved (ISO8601 timestamp)"
    },
    "execution_started_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "When remediation execution started (ISO8601 timestamp)"
    },
    "execution_completed_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "When remediation execution completed (ISO8601 timestamp)"
    },
    "actual_duration_minutes": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Actual time taken (calculated when completed)"
    },
    "work_unit_id": {
      "type": ["string", "null"],
      "description": "FK to L52 work_execution_units (SET_NULL). Work unit executing this remediation.",
      "pattern": "^workunit-[0-9]{8}-[a-z0-9-]+$"
    },
    "success": {
      "type": ["boolean", "null"],
      "description": "Whether remediation succeeded (null until completed/failed)"
    },
    "failure_reason": {
      "type": ["string", "null"],
      "description": "Why remediation failed (if status=failed)"
    },
    "lessons_learned": {
      "type": ["string", "null"],
      "description": "Post-remediation lessons (feeds L57 work_learning_feedback)"
    },
    "notes": {
      "type": "string",
      "description": "Additional execution notes or deviations from plan"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp (ISO8601)"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record last update timestamp (ISO8601)"
    },
    "created_by": {
      "type": "string",
      "description": "Identifier of creator (automated system or human operator)"
    },
    "updated_by": {
      "type": ["string", "null"],
      "description": "Identifier of last updater"
    }
  },
  "additionalProperties": false
}
