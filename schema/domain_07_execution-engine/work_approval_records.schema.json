{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://eva-models.local/schema/work_approval_records.schema.json",
  "title": "Work Approval Records",
  "type": "object",
  "description": "Approval sign-offs for DPDCA ACT phase (L62 - Execution Engine Phase 2)",
  "required": [
    "approval_id",
    "work_unit_id",
    "approval_type",
    "approver_type",
    "approver_id"
  ],
  "properties": {
    "approval_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+-approval-[0-9]{8}-[0-9]{3,}$"
    },
    "work_unit_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+-wu-[0-9]{8}-[0-9]{3,}$"
    },
    "approval_type": {
      "type": "string",
      "enum": [
        "deployment",
        "code_review",
        "security_review",
        "budget",
        "regulatory",
        "go_live"
      ],
      "description": "What is being approved"
    },
    "approver_type": {
      "type": "string",
      "enum": ["human", "agent", "automated_policy"],
      "description": "Type of approver"
    },
    "approver_id": {
      "type": "string",
      "description": "Polymorphic FK: persona_id, agent_id, or policy_id"
    },
    "approval_status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "approved_with_conditions",
        "rejected",
        "deferred"
      ]
    },
    "approval_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "approval_comment": {
      "type": "string",
      "description": "Approver's notes",
      "maxLength": 3000
    },
    "conditions_if_approved": {
      "type": "array",
      "description": "If 'approved_with_conditions', list the conditions",
      "items": { "type": "string" }
    },
    "escalation_path": {
      "type": "array",
      "description": "If rejected, who else can override?",
      "items": {
        "type": "object",
        "properties": {
          "escalation_level": { "type": "integer" },
          "approver_type": { "type": "string" },
          "approver_id": { "type": "string" }
        }
      }
    },
    "rejection_reason": {
      "type": "string",
      "description": "If rejected, detailed reason"
    },
    "can_be_overridden": {
      "type": "boolean",
      "description": "Is this decision final or can it be escalated?"
    },
    "deferral_reason": {
      "type": "string",
      "description": "If deferred, why and when to revisit"
    },
    "revisit_date": {
      "type": "string",
      "format": "date"
    }
  }
}
