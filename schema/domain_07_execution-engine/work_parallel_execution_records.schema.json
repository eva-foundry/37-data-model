{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://eva-models.local/schema/work_parallel_execution_records.schema.json",
  "title": "Work Parallel Execution Records",
  "type": "object",
  "description": "Tracking of concurrent/parallel task execution (L70 - Execution Engine Phase 4)",
  "required": [
    "execution_record_id",
    "work_unit_id",
    "parallel_group_id"
  ],
  "properties": {
    "execution_record_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+-parallel-[0-9]{8}-[0-9]{3,}$"
    },
    "work_unit_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+-wu-[0-9]{8}-[0-9]{3,}$"
    },
    "parallel_group_id": {
      "type": "string",
      "description": "Identifier for this batch of parallel tasks"
    },
    "task_count": {
      "type": "integer",
      "description": "Number of tasks running in parallel",
      "minimum": 2
    },
    "tasks": {
      "type": "array",
      "description": "Individual parallel tasks",
      "items": {
        "type": "object",
        "properties": {
          "task_id": { "type": "string" },
          "task_name": { "type": "string" },
          "execution_agent_id": { "type": "string" },
          "started_at": { "type": "string", "format": "date-time" },
          "completed_at": { "type": "string", "format": "date-time" },
          "status": { "type": "string", "enum": ["pending", "running", "completed", "failed"] },
          "result": { "type": "object" },
          "error": { "type": "string" }
        }
      }
    },
    "synchronization_point": {
      "type": "string",
      "description": "What event causes all parallel tasks to complete?"
    },
    "group_started_at": {
      "type": "string",
      "format": "date-time"
    },
    "group_completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "total_duration_seconds": {
      "type": "number"
    },
    "slowest_task_seconds": {
      "type": "number",
      "description": "Duration of slowest task (determines overall time)"
    },
    "fastest_task_seconds": {
      "type": "number"
    },
    "all_passed": {
      "type": "boolean",
      "description": "Did all tasks succeed?"
    },
    "failure_count": {
      "type": "integer",
      "description": "Number of failed tasks"
    },
    "failure_mode": {
      "type": "string",
      "enum": ["fail_fast", "fail_slow", "ignore_failures", "partial_success"],
      "description": "How are failures handled?"
    },
    "retry_failed_tasks": {
      "type": "boolean",
      "description": "Should failed tasks be retried?"
    },
    "resource_parallelism": {
      "type": "object",
      "description": "Resource consumption snapshot",
      "properties": {
        "concurrent_compute_units": { "type": "number" },
        "concurrent_network_mbps": { "type": "number" },
        "peak_memory_gb": { "type": "number" }
      }
    },
    "speedup_factor": {
      "type": "number",
      "description": "Actual time / (sequential_time / parallel_task_count) - efficiency metric"
    }
  }
}
