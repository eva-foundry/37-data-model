{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://eva-models.local/schema/work_validation_results.schema.json",
  "title": "Work Validation Results",
  "type": "object",
  "description": "Test execution results and pass/fail outcomes (L58 - Execution Engine Phase 2)",
  "required": [
    "validation_id",
    "work_unit_id",
    "test_suite_name",
    "total_tests",
    "passed_tests",
    "failed_tests"
  ],
  "properties": {
    "validation_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+-validation-[0-9]{8}-[0-9]{3,}$"
    },
    "work_unit_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+-wu-[0-9]{8}-[0-9]{3,}$"
    },
    "test_suite_name": {
      "type": "string",
      "description": "Name/identifier of test suite",
      "minLength": 1,
      "maxLength": 200
    },
    "test_type": {
      "type": "string",
      "enum": ["unit", "integration", "e2e", "performance", "security"],
      "description": "Classification of tests"
    },
    "total_tests": { "type": "integer", "minimum": 0 },
    "passed_tests": { "type": "integer", "minimum": 0 },
    "failed_tests": { "type": "integer", "minimum": 0 },
    "skipped_tests": { "type": "integer", "minimum": 0, "default": 0 },
    "pass_rate_percent": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "failed_test_details": {
      "type": "array",
      "description": "Details of each failure",
      "items": {
        "type": "object",
        "properties": {
          "test_name": { "type": "string" },
          "error_message": { "type": "string" },
          "stack_trace": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] }
        }
      }
    },
    "execution_duration_ms": {
      "type": "number",
      "description": "Total test execution time"
    },
    "environment": {
      "type": "string",
      "enum": ["local", "staging", "production"],
      "description": "Where tests were executed"
    },
    "executed_at": {
      "type": "string",
      "format": "date-time"
    },
    "executed_by": {
      "type": "string",
      "description": "Agent ID or persona ID that ran tests"
    }
  }
}
