{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "literal.schema.json",
  "title": "EVA UI Literal",
  "description": "A UI string key with translations — every displayed string in admin-face and chat-face",
  "type": "object",
  "required": ["key", "default_en", "default_fr", "screens", "status"],
  "additionalProperties": false,
  "properties": {
    "key": {
      "type": "string",
      "description": "i18n key in dot-notation",
      "examples": ["btn.save", "lbl.locale", "col.translation_key", "error.not_found"]
    },
    "default_en": { "type": "string" },
    "default_fr": { "type": "string" },
    "screens": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Screen ids that display this literal"
    },
    "category": {
      "type": ["string", "null"],
      "enum": ["button", "label", "column_header", "error", "placeholder", "tooltip", "title", "nav", null]
    },
    "status": {
      "type": "string",
      "enum": ["active", "planned", "deprecated"]
    }
  }
}
