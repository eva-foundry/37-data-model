{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "service.schema.json",
  "title": "EVA Service",
  "description": "A deployable service in the EVA ecosystem",
  "type": "object",
  "required": ["id", "label", "type", "tech_stack", "status"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier, kebab-case",
      "examples": ["eva-brain-api", "eva-roles-api", "admin-face"]
    },
    "label": { "type": "string", "description": "Human-readable name" },
    "type": {
      "type": "string",
      "enum": [
        "fastapi_backend", "react_spa", "fastapi_agent_fleet",
        "azure_apim", "azure_foundry", "pipeline", "legacy", "internal_api",
        "cli_tool", "test_harness", "automation", "copilot_library", "security_framework",
        "react_component_library"
      ]
    },
    "tech_stack": {
      "type": "array",
      "items": { "type": "string" },
      "description": "e.g. ['Python 3.10', 'FastAPI', 'Pydantic', 'Azure Cosmos DB']"
    },
    "repo_path": {
      "type": "string",
      "description": "Relative path from eva-foundation root",
      "examples": ["33-eva-brain-v2/services/eva-brain-api"]
    },
    "port": { "type": ["integer", "null"], "description": "Local dev port; null if not applicable" },
    "base_url_local": { "type": ["string", "null"], "examples": ["http://localhost:8001"] },
    "base_url_azure": { "type": ["string", "null"], "description": "Deployed Azure URL or null" },
    "health_endpoint": { "type": ["string", "null"], "examples": ["/health"] },
    "status": {
      "type": "string",
      "enum": ["running", "partial", "stub", "planned", "legacy", "deprecated"]
    },
    "depends_on": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Service ids this service calls at runtime"
    },
    "boot_order": {
      "type": "integer",
      "description": "Start-up ordering weight — lower numbers boot first (default 99)",
      "default": 99
    },
    "deploy_order": {
      "type": "integer",
      "description": "Deployment ordering weight — lower numbers deploy first (default 99)",
      "default": 99
    },
    "notes": { "type": ["string", "null"] }
  }
}
