{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "container.schema.json",
  "title": "EVA Cosmos Container",
  "description": "A Cosmos DB container — fields, partition key, indexes",
  "type": "object",
  "required": ["id", "database", "partition_key", "fields", "status"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Cosmos container name",
      "examples": ["translations", "sessions", "audit"]
    },
    "label": { "type": "string" },
    "database": { "type": "string", "description": "Cosmos database name" },
    "partition_key": { "type": "string", "examples": ["/locale", "/persona_id", "/session_id"] },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "required"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "examples": ["str", "int", "bool", "list", "dict", "datetime"] },
          "required": { "type": "boolean" },
          "indexed": { "type": "boolean" },
          "unique": { "type": "boolean" },
          "default": {},
          "description": { "type": "string" }
        }
      }
    },
    "indexes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fields", "kind"],
        "properties": {
          "fields": { "type": "array", "items": { "type": "string" } },
          "kind": { "type": "string", "enum": ["Hash", "Range", "Spatial", "Composite"] }
        }
      }
    },
    "ttl_seconds": { "type": ["integer", "null"] },
    "status": {
      "type": "string",
      "enum": ["active", "planned", "deprecated"]
    },
    "data_function_type": {
      "type": ["string", "null"],
      "enum": ["ILF", "EIF", null],
      "description": "IFPUG data function type: ILF = Internal Logical File (owned), EIF = External Interface File (referenced). Used by GET /model/fp/estimate."
    },
    "det_count": {
      "type": ["integer", "null"],
      "description": "IFPUG Data Element Type count — derived from fields array length if null"
    },
    "notes": { "type": ["string", "null"] }
  }
}
