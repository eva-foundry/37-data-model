{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://eva-models.local/schema/infrastructure_security_policies.schema.json",
  "title": "Infrastructure Security Policies",
  "type": "object",
  "description": "Cloud security policies and controls (L82 - Security Phase 2)",
  "required": [
    "policy_id",
    "policy_name",
    "cloud_provider",
    "policy_category"
  ],
  "properties": {
    "policy_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+-infra-policy-[0-9]{8}-[0-9]{3,}$"
    },
    "policy_name": {
      "type": "string",
      "description": "Human-readable policy name"
    },
    "policy_description": {
      "type": "string",
      "minLength": 20
    },
    "cloud_provider": {
      "type": "string",
      "enum": ["Azure", "AWS", "GCP", "multi-cloud", "on-premises"],
      "description": "Which cloud platform(s)"
    },
    "policy_category": {
      "type": "string",
      "enum": [
        "identity_access",
        "network",
        "encryption",
        "data_protection",
        "logging",
        "monitoring",
        "resource_governance",
        "threat_protection"
      ]
    },
    "policy_version": {
      "type": "string"
    },
    "created_date": {
      "type": "string",
      "format": "date"
    },
    "last_updated_date": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string",
      "description": "Team responsible for this policy"
    },
    "policy_statement": {
      "type": "string",
      "description": "Detailed policy statement and rules",
      "minLength": 50
    },
    "enforcement_mechanism": {
      "type": "string",
      "enum": ["manual_review", "automated_policy", "hybrid"],
      "description": "How is this enforced?"
    },
    "automation_tool": {
      "type": "string",
      "description": "If automated, what tool enforces it? (e.g., 'Azure Policy', 'AWS Config')"
    },
    "policy_rules": {
      "type": "array",
      "description": "Specific rules within this policy",
      "items": {
        "type": "object",
        "properties": {
          "rule_id": { "type": "string" },
          "rule_description": { "type": "string" },
          "condition": { "type": "string" },
          "action_if_violated": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] }
        }
      }
    },
    "scope": {
      "type": "array",
      "description": "What resources/services does this apply to?",
      "items": { "type": "string" }
    },
    "exceptions": {
      "type": "array",
      "description": "Documented exceptions to this policy",
      "items": {
        "type": "object",
        "properties": {
          "exception_id": { "type": "string" },
          "resource_affected": { "type": "string" },
          "reason": { "type": "string" },
          "approved_by": { "type": "string" },
          "expiry_date": { "type": "string", "format": "date" }
        }
      }
    },
    "compliance_frameworks": {
      "type": "array",
      "description": "Which compliances does this support?",
      "items": { "type": "string" }
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "enforcement_status": {
      "type": "string",
      "enum": ["not_enforced", "enforced", "enforced_with_audit", "audit_only"],
      "description": "Is this actively enforced?"
    },
    "audit_findings_related": {
      "type": "array",
      "description": "Related security audit records (L81)",
      "items": { "type": "string" }
    }
  }
}
