{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "component.schema.json",
  "title": "EVA UI Component",
  "description": "A reusable React component in the EVA design system (@eva/ui or screen-local)",
  "type": "object",
  "required": ["id", "label", "package", "status"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "PascalCase component identifier",
      "examples": ["AdminListPage", "EvaBadge", "EvaButton", "EvaDialog"]
    },
    "label": { "type": "string", "description": "Human-readable component name" },
    "package": {
      "type": "string",
      "description": "NPM package or monorepo path that exports this component",
      "examples": ["@eva/ui", "31-eva-faces/admin-face/src/components/AdminListPage"]
    },
    "repo_path": {
      "type": ["string", "null"],
      "description": "Relative path from eva-foundation root to the component file"
    },
    "repo_line": { "type": ["integer", "null"], "description": "1-based line of the component function/export declaration" },
    "props": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Key prop names (documentation only)"
    },
    "used_by_screens": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Screen ids that use this component"
    },
    "a11y_notes": {
      "type": ["string", "null"],
      "description": "WCAG / ARIA compliance notes for this component"
    },
    "status": {
      "type": "string",
      "enum": ["implemented", "poc", "stub", "planned", "deprecated"]
    },
    "notes": { "type": ["string", "null"] }
  }
}
