{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://eva-models.local/schema/red_team_campaigns.schema.json",
  "title": "Red Team Campaigns",
  "type": "object",
  "description": "Red-teaming exercises and adversarial testing campaigns (L76 - Security Phase 1, Project 36)",
  "required": [
    "campaign_id",
    "campaign_name",
    "target_system",
    "campaign_start_date"
  ],
  "properties": {
    "campaign_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+-redteam-[0-9]{8}-[0-9]{3,}$"
    },
    "campaign_name": {
      "type": "string",
      "description": "Name of this red-teaming exercise",
      "minLength": 5
    },
    "target_system": {
      "type": "string",
      "description": "What system(s) are being tested?"
    },
    "campaign_description": {
      "type": "string",
      "minLength": 20
    },
    "campaign_start_date": {
      "type": "string",
      "format": "date-time"
    },
    "campaign_end_date": {
      "type": "string",
      "format": "date-time"
    },
    "red_team_lead": {
      "type": "string",
      "description": "exercise_lead persona_id"
    },
    "blue_team_lead": {
      "type": "string",
      "description": "Defender contact"
    },
    "scope": {
      "type": "string",
      "enum": [
        "application",
        "infrastructure",
        "network",
        "supply_chain",
        "social_engineering",
        "physical",
        "full_system"
      ]
    },
    "threat_frameworks": {
      "type": "array",
      "description": "MITRE ATLAS tactics / OWASP categories being tested",
      "items": { "type": "string" }
    },
    "authorized_targets": {
      "type": "array",
      "description": "Specific systems/endpoints authorized for testing",
      "items": { "type": "string" }
    },
    "out_of_scope": {
      "type": "array",
      "description": "What is NOT included",
      "items": { "type": "string" }
    },
    "rules_of_engagement": {
      "type": "string",
      "description": "Exercise constraints and limitations"
    },
    "findings": {
      "type": "array",
      "description": "Vulnerabilities/weaknesses discovered",
      "items": {
        "type": "object",
        "properties": {
          "finding_id": { "type": "string" },
          "tactic": { "type": "string" },
          "technique": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "description": { "type": "string" },
          "proof_of_concept": { "type": "string" },
          "cvss_score": { "type": "number" }
        }
      }
    },
    "total_attack_paths_discovered": {
      "type": "integer"
    },
    "critical_findings": {
      "type": "integer"
    },
    "high_findings": {
      "type": "integer"
    },
    "exploited_vulnerabilities": {
      "type": "array",
      "description": "CVEs/vulnerabilities successfully exploited",
      "items": { "type": "string" }
    },
    "defensive_improvements": {
      "type": "array",
      "description": "Recommendations for improving defenses",
      "items": {
        "type": "object",
        "properties": {
          "improvement_id": { "type": "string" },
          "description": { "type": "string" },
          "priority": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "owner": { "type": "string" },
          "target_completion_date": { "type": "string", "format": "date" }
        }
      }
    },
    "lessons_learned": {
      "type": "string",
      "description": "Key takeaways from this campaign"
    },
    "status": {
      "type": "string",
      "enum": ["planned", "in_progress", "completed", "paused"],
      "description": "Campaign status"
    },
    "approval_status": {
      "type": "string",
      "enum": ["not_approved", "approved_preliminary", "approved_full"],
      "description": "Executive approval level"
    }
  }
}
