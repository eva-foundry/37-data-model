{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agent.schema.json",
  "title": "EVA Agent Fleet Agent",
  "description": "A FastAPI agent in the agent-fleet orchestrator",
  "type": "object",
  "required": ["id", "label", "skill_file", "input_type", "output_type", "llm_deployment", "status"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Python module/class name, kebab-case",
      "examples": ["screen-generator", "test-generator", "api-client-generator"]
    },
    "label": { "type": "string" },
    "skill_file": { "type": "string", "description": "Relative path to skill .py file in agent-fleet/app/" },
    "input_type": {
      "type": "string",
      "enum": ["epic", "endpoint_id", "screen_id", "source_file", "requirement_id"]
    },
    "output_type": {
      "type": "string",
      "enum": ["tsx_file", "test_file", "api_client_file", "validation_report", "evidence_bundle"]
    },
    "llm_deployment": { "type": "string", "examples": ["gpt-5.1-chat", "gpt-4o"] },
    "output_screens": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Screen ids this agent generates"
    },
    "endpoints_consumed": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Endpoint ids this agent reads to produce output"
    },
    "status": {
      "type": "string",
      "enum": ["active", "planned", "deprecated"]
    },
    "notes": { "type": ["string", "null"] }
  }
}
