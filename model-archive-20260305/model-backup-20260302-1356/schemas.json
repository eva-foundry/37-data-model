          "type": "str",
          "required": false,
          "nullable": true,
          "description": "agile | waterfall | hybrid"
        },
        {
          "name": "owner",
          "type": "str",
          "required": false,
          "nullable": true,
          "description": "Person accountable for this WBS node"
        },
        {
          "name": "team",
          "type": "str",
          "required": false,
          "nullable": true,
          "description": "Team responsible"
        },
        {
          "name": "status",
          "type": "str",
          "required": true,
          "description": "planned | active | in_progress | done | on_hold | cancelled"
