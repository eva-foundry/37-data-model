# Secrets -- never commit
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/

# pytest / coverage / test data
.pytest_cache/
.coverage
htmlcov/
.hypothesis/

# OS
desktop.ini
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
*.swp
*.swo

# Temp / debug / backup files
*.log
*.backup*
acr-build*.log
acr-build-*.log
sync-output.txt
tmp_len.txt
tmp-*.json
*-tmp.json
fix_*.py
add_*.py
update_*.py
debug-*.py

# Reports and temporary documentation
*-REPORT.md
*-SUMMARY.md
!RCA-*.md
!CONSISTENCY-*.md

# Archives and exports
model-archive*/
model-archive-*/
*-export-*/
eva-data-model-export-*/

# Temporary scripts (one-off debugging/testing)
scripts/audit-*.ps1
scripts/debug-*.ps1
scripts/fix-*.ps1
scripts/test-*.ps1
scripts/tmp-*.ps1

# Cosmos DB exports (transient sync data)
# Note: Base model/*.json files ARE tracked for CI/CD seed data (force-added)
# This pattern only prevents NEW files from being accidentally committed
# Tracked files: services.json, evidence.json, etc. (38 layers + eva-model.json)
model/*.json
!model/.gitkeep
