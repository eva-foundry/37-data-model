          "    substitute variables (LAYER_ID, LAYER_NAME, etc.)",
          "    write output to 37-data-model/ui/src/pages/{LayerName}/{Component}.tsx",
          "    log evidence.component_generated"
          "  }",
          "  if (all 5 components successful) { evidence.screen_complete = true }",
          "}"
        ],
        "error_handling": "On any component failure: log error, add to failed_screens array, continue with next screen",
        "parallelization": "Option: Run substitutions in parallel jobs (2-8 workers)"
      },
