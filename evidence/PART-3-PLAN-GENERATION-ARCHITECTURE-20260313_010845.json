    "error_handling_strategy": {
      "template_not_found": {
        "severity": "CRITICAL",
        "action": "FAIL entire generation for that component",
        "recovery": "Copy template from 07-foundation-layer, retry"
      },
      "registry_read_error": {
        "severity": "CRITICAL",
        "action": "FAIL generation",
        "recovery": "Fall back to JSON file, verify record count"
      },
      "substitution_error": {
        "severity": "HIGH",
        "action": "Log error, add to failed_screens, continue with next",
        "recovery": "Review substitution rule for that variable, fix template or data"
      },
      "file_write_error": {
        "severity": "HIGH",
        "action": "Log error, continue with next",
        "recovery": "Check disk space, verify permissions, retry after manual verification"
      },
      "typescript_compilation_error": {
        "severity": "MEDIUM",
        "action": "Collect all errors, generate report",
        "recovery": "Fix template or generated output, regenerate affected components"
      }
    },
    
