{
  "deployment_policies": [
    {
      "id": "51-ACA-deployment",
      "project_id": "51-ACA",
      "project_name": "Academic Case Analysis",
      "description": "Container App deployment policy for 51-ACA Evidence API",
      "container_app": {
        "name": "aca-evidence-api",
        "resource_group": "51-ACA-RG",
        "subscription": "MarcoSub"
      },
      "resource_limits": {
        "cpu": "0.25",
        "memory": "0.5Gi",
        "ephemeral_storage": "1Gi"
      },
      "scaling": {
        "min_replicas": 0,
        "max_replicas": 2,
        "scale_rule": "http",
        "concurrent_requests": 10
      },
      "health_probes": {
        "liveness": {
          "path": "/health",
          "initial_delay_seconds": 10,
          "period_seconds": 30,
          "timeout_seconds": 5
        },
        "readiness": {
          "path": "/ready",
          "initial_delay_seconds": 5,
          "period_seconds": 10,
          "timeout_seconds": 3
        },
        "startup": {
          "path": "/startup",
          "initial_delay_seconds": 0,
          "period_seconds": 5,
          "timeout_seconds": 3,
          "failure_threshold": 12
        }
      },
      "revision_strategy": {
        "mode": "single",
        "traffic_split_enabled": false,
        "blue_green_enabled": false,
        "rollback_policy": "automatic_on_health_failure"
      },
      "deployment_gates": [
        "pytest_pass",
        "validate_model_pass"
      ],
      "environment_variables": {
        "PYTHONUNBUFFERED": "1",
        "LOG_LEVEL": "INFO",
        "COSMOS_DB_NAME": "aca-evidence"
      },
      "is_active": true
    },
