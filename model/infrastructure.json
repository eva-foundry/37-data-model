{
  "$schema": "../schema/infrastructure.schema.json",
  "infrastructure": [
    {
      "id": "openai-brain-deployment",
      "type": "openai_deployment",
      "azure_resource_name": "marco-sandbox-openai-v2",
      "service": "eva-brain-api",
      "env_var": "AZURE_OPENAI_ENDPOINT",
      "keyvault_secret_name": "eva-openai-api-key",
      "status": "provisioned",
      "notes": "gpt-5.1-chat deployment. Endpoint: https://marco-sandbox-openai-v2.openai.azure.com/"
    },
    {
      "id": "openai-agent-deployment",
      "type": "openai_deployment",
      "azure_resource_name": "esdaicoe-ai-foundry-openai",
      "service": "agent-fleet",
      "env_var": "AZURE_OPENAI_ENDPOINT",
      "keyvault_secret_name": "agent-fleet-openai-api-key",
      "status": "provisioned",
      "notes": "gpt-5.1-chat deployment for agent-fleet. Endpoint: https://esdaicoe-ai-foundry-openai.openai.azure.com/"
    },
    {
      "id": "ai-search-index",
      "type": "azure_search_index",
      "azure_resource_name": "marco-sandbox-search",
      "service": "eva-brain-api",
      "env_var": "AZURE_SEARCH_ENDPOINT",
      "keyvault_secret_name": "eva-search-api-key",
      "status": "provisioned",
      "notes": "Index: proj10-index. Env var AZURE_SEARCH_INDEX holds the index name."
    },
    {
      "id": "cosmos-account",
      "type": "cosmos_account",
      "azure_resource_name": "eva-cosmos-account",
      "service": "eva-brain-api",
      "env_var": "AZURE_COSMOS_ENDPOINT",
      "keyvault_secret_name": "eva-cosmos-key",
      "status": "provisioned",
      "notes": "Azure Cosmos DB for NoSQL. Shared by eva-brain-api and eva-roles-api."
    },
    {
      "id": "cosmos-database",
      "type": "cosmos_database",
      "azure_resource_name": "eva-db",
      "service": "eva-brain-api",
      "env_var": "AZURE_COSMOS_DATABASE",
      "status": "provisioned",
      "notes": "Parent database for all EVA Cosmos containers."
    },
    {
      "id": "cosmos-container-jobs",
      "type": "cosmos_container",
      "azure_resource_name": "jobs",
      "service": "eva-brain-api",
      "references": "jobs",
      "status": "provisioned",
      "notes": "Ingest job tracker. Partition key: /actor_oid."
    },
    {
      "id": "cosmos-container-statusdb",
      "type": "cosmos_container",
      "azure_resource_name": "statusdb",
      "service": "eva-brain-api",
      "references": "statusdb",
      "status": "provisioned",
      "notes": "Service health and operational status. Partition key: /service_id."
    },
    {
      "id": "cosmos-container-documents",
      "type": "cosmos_container",
      "azure_resource_name": "documents",
      "service": "eva-brain-api",
      "references": "documents",
      "status": "provisioned",
      "notes": "Document metadata records. Partition key: /actor_oid."
    },
    {
      "id": "cosmos-container-chunks",
      "type": "cosmos_container",
      "azure_resource_name": "chunks",
      "service": "eva-brain-api",
      "references": "chunks",
      "status": "provisioned",
      "notes": "Text chunks + embeddings. Partition key: /document_id. TTL: 90 days."
    },
    {
      "id": "cosmos-container-tags",
      "type": "cosmos_container",
      "azure_resource_name": "tags",
      "service": "eva-brain-api",
      "references": "tags",
      "status": "provisioned",
      "notes": "Document tags and taxonomy. Partition key: /actor_oid."
    },
    {
      "id": "cosmos-container-sessions",
      "type": "cosmos_container",
      "azure_resource_name": "sessions",
      "service": "eva-brain-api",
      "references": "sessions",
      "status": "planned",
      "notes": "Conversation sessions. Partition key: /actor_oid. TTL: 90 days."
    },
    {
      "id": "cosmos-container-messages",
      "type": "cosmos_container",
      "azure_resource_name": "messages",
      "service": "eva-brain-api",
      "references": "messages",
      "status": "planned",
      "notes": "Chat messages within sessions. Partition key: /session_id."
    },
    {
      "id": "storage-account",
      "type": "storage_account",
      "azure_resource_name": "eva-storage",
      "service": "eva-brain-api",
      "env_var": "AZURE_STORAGE_ACCOUNT_NAME",
      "keyvault_secret_name": "eva-storage-account-key",
      "status": "provisioned",
      "notes": "Azure Blob Storage for document uploads and processed content."
    },
    {
      "id": "storage-container-upload",
      "type": "storage_container",
      "azure_resource_name": "documents-upload",
      "service": "eva-brain-api",
      "env_var": "AZURE_STORAGE_CONTAINER_UPLOAD",
      "status": "provisioned",
      "notes": "Blob container for raw document uploads before ingest processing."
    },
    {
      "id": "appinsights",
      "type": "foundry_project",
      "azure_resource_name": "eva-appinsights",
      "service": "eva-brain-api",
      "env_var": "APPINSIGHTS_CONNECTION_STRING",
      "keyvault_secret_name": "eva-appinsights-connection-string",
      "status": "planned",
      "notes": "Application Insights for telemetry. Connection string empty in dev .env."
    },
    {
      "id": "entra-app-registration",
      "type": "entra_app_registration",
      "azure_resource_name": "eva-brain-api-sp",
      "service": "eva-brain-api",
      "env_var": "AZURE_CLIENT_ID",
      "keyvault_secret_name": "eva-azure-client-secret",
      "status": "planned",
      "notes": "Service principal. AZURE_TENANT_ID + AZURE_CLIENT_ID + AZURE_CLIENT_SECRET. Dev bypasses via DEV_BYPASS_OID."
    },
    {
      "id": "apim-instance",
      "type": "apim_api",
      "azure_resource_name": "marco-sandbox-apim",
      "service": "eva-brain-api",
      "status": "planned",
      "notes": "Azure API Management gateway fronting all /v1/* EVA Brain endpoints. Import scheduled Mar 29-30, 2026."
    },
    {
      "id": "brain-api-container-app",
      "type": "container_app",
      "azure_resource_name": "eva-brain-api",
      "service": "eva-brain-api",
      "status": "planned",
      "notes": "Container App running uvicorn on port 8001. All AZURE_* env vars injected at runtime."
    },
    {
      "id": "roles-api-container-app",
      "type": "container_app",
      "azure_resource_name": "eva-roles-api",
      "service": "eva-roles-api",
      "env_var": "ROLES_API_URL",
      "status": "planned",
      "notes": "Container App running the roles/RBAC service on port 8002."
    },
    {
      "id": "agent-fleet-container-app",
      "type": "container_app",
      "azure_resource_name": "eva-agent-fleet",
      "service": "agent-fleet",
      "status": "planned",
      "notes": "Container App running the agent-fleet FastAPI orchestrator on port 8003."
    },
    {
      "id": "admin-static-web-app",
      "type": "container_app",
      "azure_resource_name": "eva-admin-face",
      "service": "admin-face",
      "env_var": "VITE_API_BASE_URL",
      "status": "planned",
      "notes": "Azure Static Web App for admin-face. Deployment scheduled Phase 4 (Mar 25-31, 2026)."
    },
    {
      "id": "chat-static-web-app",
      "type": "container_app",
      "azure_resource_name": "eva-chat-face",
      "service": "chat-face",
      "env_var": "VITE_API_BASE_URL",
      "status": "planned",
      "notes": "Azure Static Web App for chat-face. Deployment scheduled Phase 4 (Mar 25-31, 2026)."
    },
    {
      "id": "keyvault",
      "type": "keyvault_vault",
      "azure_resource_name": "eva-keyvault",
      "service": "eva-brain-api",
      "status": "planned",
      "notes": "Azure Key Vault. Secrets configuration scheduled Mar 31 - Apr 4, 2026."
    }
  ]
}
