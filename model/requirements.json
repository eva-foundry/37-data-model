    {
      "id": "REQ-037-E09",
      "title": "Add 'docs' layer to EVA Data Model for document and deliverable metadata",
      "type": "feature",
      "status": "proposed",
      "sprint": "backlog",
      "satisfied_by": [],
      "test_ids": [],
      "depends_on": [],
      "notes": "Motivation: EVA State Paper (19-ai-gov D-15) had to be registered as a requirements entry (REQ-019-D15) because the model has no docs/deliverables layer. This is a workaround that conflates two distinct concerns. Proposed layer name: 'docs'. Minimum fields: id (e.g. DOC-019-001), title, type (paper|spec|runbook|decision|diagram), project, status (draft|review|published|archived), path (repo-relative file path), format (md|pdf|docx), author, sprint, tags, parent_doc, is_active. This layer would cleanly host: position papers, architecture specs, design decisions, runbooks, and any other project deliverable that today has no dedicated home in the model. Raised: 2026-02-24 after 19-ai-gov Phase 7 (EVA State Paper) work.",
      "source_file": "model/requirements.json",
      "is_active": true,
      "modified_by": "agent:copilot",
      "modified_at": "2026-02-24T14:54:18.049915+00:00",
