{
  "$schema": "../schema/container.schema.json",
  "containers": [
    {
      "id": "jobs",
      "label": "Ingestion Jobs",
      "database": "statusdb",
      "partition_key": "/actor_oid",
      "fields": [
        { "name": "id",           "type": "str",      "required": true,  "indexed": true,  "description": "Unique job UUID" },
        { "name": "actor_oid",    "type": "str",      "required": true,  "indexed": true,  "description": "AAD OID of submitting user" },
        { "name": "file_name",    "type": "str",      "required": true,  "indexed": false, "description": "Original file name" },
        { "name": "file_type",    "type": "str",      "required": true,  "indexed": false, "description": "MIME type / extension" },
        { "name": "blob_url",     "type": "str",      "required": true,  "indexed": false, "description": "Azure Blob URL" },
        { "name": "indexes",      "type": "list",     "required": false, "indexed": false, "description": "Target search index names" },
        { "name": "status",       "type": "str",      "required": true,  "indexed": true,  "description": "JobStatus enum value" },
        { "name": "created_at",   "type": "datetime", "required": true,  "indexed": true,  "description": "Job creation timestamp" },
        { "name": "updated_at",   "type": "datetime", "required": true,  "indexed": false, "description": "Last status update timestamp" },
        { "name": "started_at",   "type": "datetime", "required": false, "indexed": false, "description": "Processing start timestamp" },
        { "name": "completed_at", "type": "datetime", "required": false, "indexed": false, "description": "Processing completion timestamp" },
        { "name": "error_message","type": "str",      "required": false, "indexed": false, "description": "Error detail if failed" },
        { "name": "retry_count",  "type": "int",      "required": false, "indexed": false, "description": "Number of retry attempts" },
        { "name": "progress",     "type": "dict",     "required": false, "indexed": false, "description": "Pipeline stage progress: parsed, enriched, chunked, embedded, indexed" },
        { "name": "metrics",      "type": "dict",     "required": false, "indexed": false, "description": "Run metrics: total_chunks, total_tokens, embedding_cost_usd, processing_time_ms" },
        { "name": "metadata",     "type": "dict",     "required": false, "indexed": false, "description": "Caller-supplied metadata" }
      ],
      "ttl_seconds": null,
      "status": "active",
      "notes": "Source: cosmos_service.py. Written by ingestion pipeline, read by ingest routes."
    },
    {
      "id": "extracted_content",
      "label": "Extracted Document Content",
      "database": "statusdb",
      "partition_key": "/job_id",
      "fields": [
        { "name": "id",      "type": "str", "required": true,  "indexed": true,  "description": "Content record ID" },
        { "name": "job_id",  "type": "str", "required": true,  "indexed": true,  "description": "Parent ingestion job ID" },
        { "name": "content", "type": "str", "required": true,  "indexed": false, "description": "Extracted text content" }
      ],
      "ttl_seconds": null,
      "status": "active",
      "notes": "Source: cosmos_service.py. Intermediate extraction store; detail fields partially inferred."
    },
    {
      "id": "chunks",
      "label": "Document Chunks",
      "database": "statusdb",
      "partition_key": "/job_id",
      "fields": [
        { "name": "id",          "type": "str",  "required": true,  "indexed": true,  "description": "Chunk ID" },
        { "name": "job_id",      "type": "str",  "required": true,  "indexed": true,  "description": "Parent ingestion job ID" },
        { "name": "content",     "type": "str",  "required": true,  "indexed": false, "description": "Chunk text" },
        { "name": "embedding",   "type": "list", "required": false, "indexed": false, "description": "Vector embedding (float[])" },
        { "name": "chunk_index", "type": "int",  "required": false, "indexed": false, "description": "Ordinal position within document" }
      ],
      "ttl_seconds": 2592000,
      "status": "active",
      "notes": "Source: cosmos_service.py. TTL = 30 days (2592000 s). Temp store before Azure AI Search indexing. Fields partially inferred."
    },
    {
      "id": "audit_logs",
      "label": "Audit Logs (Lane A)",
      "database": "statusdb",
      "partition_key": "/actor_oid",
      "fields": [
        { "name": "id",             "type": "str",      "required": true,  "indexed": true,  "description": "Log entry ID" },
        { "name": "actor_oid",      "type": "str",      "required": true,  "indexed": true,  "description": "AAD OID of acting user" },
        { "name": "correlation_id", "type": "str",      "required": true,  "indexed": true,  "description": "Request correlation ID" },
        { "name": "action",         "type": "str",      "required": true,  "indexed": true,  "description": "Action performed" },
        { "name": "result_summary", "type": "dict",     "required": false, "indexed": false, "description": "Outcome details" },
        { "name": "environment",    "type": "str",      "required": false, "indexed": false, "description": "Deployment environment" },
        { "name": "timestamp",      "type": "datetime", "required": true,  "indexed": true,  "description": "Audit timestamp" }
      ],
      "ttl_seconds": null,
      "status": "active",
      "notes": "Source: cosmos_service.py. Permanent audit trail — no TTL. Written by AuditLogger.log_lane_a()."
    },
    {
      "id": "content_access_logs",
      "label": "Content Access Logs (Break-Glass)",
      "database": "statusdb",
      "partition_key": "/actor_oid",
      "fields": [
        { "name": "id",             "type": "str",      "required": true,  "indexed": true,  "description": "Log entry ID" },
        { "name": "actor_oid",      "type": "str",      "required": true,  "indexed": true,  "description": "AAD OID of accessing user" },
        { "name": "correlation_id", "type": "str",      "required": true,  "indexed": true,  "description": "Request correlation ID" },
        { "name": "document_id",    "type": "str",      "required": false, "indexed": true,  "description": "Accessed document ID" },
        { "name": "access_type",    "type": "str",      "required": false, "indexed": false, "description": "read | download | chunk" },
        { "name": "timestamp",      "type": "datetime", "required": true,  "indexed": true,  "description": "Access timestamp" }
      ],
      "ttl_seconds": 86400,
      "status": "active",
      "notes": "Source: cosmos_service.py. TTL = 24 h (86400 s). Break-glass / privileged access tracking."
    },
    {
      "id": "sessions",
      "label": "Chat Sessions",
      "database": "statusdb",
      "partition_key": "/actor_oid",
      "fields": [
        { "name": "id",              "type": "str",      "required": true,  "indexed": true,  "description": "Session UUID" },
        { "name": "actor_oid",       "type": "str",      "required": true,  "indexed": true,  "description": "Session owner AAD OID" },
        { "name": "title",           "type": "str",      "required": true,  "indexed": false, "description": "Session display title" },
        { "name": "persona",         "type": "str",      "required": true,  "indexed": false, "description": "User persona at session creation" },
        { "name": "created_at",      "type": "datetime", "required": true,  "indexed": true,  "description": "Creation timestamp" },
        { "name": "updated_at",      "type": "datetime", "required": true,  "indexed": false, "description": "Last update timestamp" },
        { "name": "message_count",   "type": "int",      "required": false, "indexed": false, "description": "Cached message count" },
        { "name": "last_message_at", "type": "datetime", "required": false, "indexed": false, "description": "Latest message timestamp" },
        { "name": "metadata",        "type": "dict",     "required": false, "indexed": false, "description": "Caller-supplied metadata" }
      ],
      "ttl_seconds": 2592000,
      "status": "active",
      "notes": "Source: sessions.py (sessions_container='sessions'). Partition key inferred as /actor_oid. TTL 30 d inferred from session_service(ttl_days=30)."
    },
    {
      "id": "messages",
      "label": "Chat Messages",
      "database": "statusdb",
      "partition_key": "/session_id",
      "fields": [
        { "name": "id",         "type": "str",      "required": true,  "indexed": true,  "description": "Message UUID" },
        { "name": "session_id", "type": "str",      "required": true,  "indexed": true,  "description": "Parent session ID" },
        { "name": "role",       "type": "str",      "required": true,  "indexed": false, "description": "user | assistant | system" },
        { "name": "content",    "type": "str",      "required": true,  "indexed": false, "description": "Message text" },
        { "name": "timestamp",  "type": "datetime", "required": true,  "indexed": true,  "description": "Message timestamp" },
        { "name": "metadata",   "type": "dict",     "required": false, "indexed": false, "description": "Token counts, model, latency, etc." }
      ],
      "ttl_seconds": 2592000,
      "status": "active",
      "notes": "Source: sessions.py (messages_container='messages'). Partition key inferred as /session_id."
    },
    {
      "id": "scrum-cache",
      "label": "Sprint Data Cache",
      "database": "eva-foundation",
      "partition_key": "/sprint_key",
      "fields": [
        { "name": "id",           "type": "str",      "required": true,  "indexed": true,  "description": "Cache key: {project}-{sprint}" },
        { "name": "sprint_key",  "type": "str",      "required": true,  "indexed": true,  "description": "Partition key matching id" },
        { "name": "payload",     "type": "dict",     "required": true,  "indexed": false, "description": "ScrumDashboardResponse JSON" },
        { "name": "generated_at","type": "datetime", "required": true,  "indexed": false, "description": "ADO sync timestamp" }
      ],
      "ttl_seconds": 86400,
      "status": "provisioned",
      "notes": "PROJECT-39 WI-0. Provisioned 2026-02-20. az cosmosdb sql container create --database-name eva-foundation --name scrum-cache --partition-key-path /sprint_key --ttl 86400"
    },
    {
      "id": "config",
      "label": "Admin Configuration Settings",
      "database": "eva-foundation",
      "partition_key": "/category",
      "fields": [
        { "name": "id",       "type": "str", "required": true,  "indexed": true,  "description": "Setting key" },
        { "name": "category", "type": "str", "required": true,  "indexed": true,  "description": "Setting category (partition key)" },
        { "name": "value",    "type": "str", "required": true,  "indexed": false, "description": "Setting value (serialized)" }
      ],
      "ttl_seconds": null,
      "status": "planned",
      "notes": "admin-face SettingsPage (WI-3). Planned brain-v2 Sprint 5."
    },
    {
      "id": "apps",
      "label": "App Registry",
      "database": "eva-foundation",
      "partition_key": "/appId",
      "fields": [
        { "name": "id",          "type": "str",  "required": true,  "indexed": true,  "description": "App identifier (slug)" },
        { "name": "appId",       "type": "str",  "required": true,  "indexed": true,  "description": "Partition key" },
        { "name": "title",       "type": "str",  "required": true,  "indexed": false, "description": "Display name" },
        { "name": "visibility",  "type": "str",  "required": true,  "indexed": true,  "description": "public | private" },
        { "name": "disabled",    "type": "bool", "required": false, "indexed": true,  "description": "Whether app is disabled" }
      ],
      "ttl_seconds": null,
      "status": "planned",
      "notes": "admin-face AppsPage (WI-4). Planned brain-v2 App Registry endpoint."
    }
  ]
}
