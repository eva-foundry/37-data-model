{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "risk.schema.json",
  "title": "EVA Risk",
  "description": "A project risk register entry. Supports both waterfall and agile risk tracking.",
  "type": "object",
  "required": ["id", "project_id", "title", "probability", "impact", "status"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Risk id, e.g. 33-eva-brain-v2-R001",
      "examples": ["33-eva-brain-v2-R001"]
    },
    "project_id": { "type": "string" },
    "title": { "type": "string", "description": "One-sentence risk statement" },
    "description": { "type": ["string", "null"] },
    "category": {
      "type": ["string", "null"],
      "enum": ["technical", "schedule", "resource", "security", "compliance", "dependency", "business", null]
    },
    "probability": {
      "type": "string",
      "enum": ["Low", "Medium", "High"],
      "description": "Likelihood of occurrence"
    },
    "impact": {
      "type": "string",
      "enum": ["Low", "Medium", "High"],
      "description": "Severity if it occurs"
    },
    "risk_score": {
      "type": ["integer", "null"],
      "description": "Computed: Low=1, Medium=2, High=3; score = probability * impact (1-9)"
    },
    "status": {
      "type": "string",
      "enum": ["open", "mitigated", "accepted", "closed", "triggered"]
    },
    "mitigation": { "type": ["string", "null"], "description": "Mitigation or contingency plan" },
    "mitigation_owner": { "type": ["string", "null"] },
    "due_date": { "type": ["string", "null"], "format": "date" },
    "sprint_id": { "type": ["string", "null"], "description": "Sprint where this risk is active" },
    "wbs_ids": {
      "type": "array",
      "items": { "type": "string" },
      "description": "WBS items affected by this risk"
    },
    "notes": { "type": ["string", "null"] }
  }
}
