{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "infrastructure.schema.json",
  "title": "EVA Infrastructure Resource",
  "description": "An Azure resource or configuration object used by the EVA ecosystem",
  "type": "object",
  "required": ["id", "type", "azure_resource_name", "service", "status"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier, kebab-case",
      "examples": ["cosmos-translations-container", "apim-v1-translations", "kv-cosmos-key"]
    },
    "type": {
      "type": "string",
      "enum": [
        "cosmos_account", "cosmos_database", "cosmos_container",
        "azure_search_index", "storage_account", "storage_container",
        "container_app", "apim_route", "apim_api",
        "keyvault_secret", "keyvault_vault",
        "openai_deployment", "foundry_project",
        "entra_app_registration", "entra_group",
        "functions_app", "static_web_app",
        "vnet", "private_endpoint", "nsg", "private_dns_zone",
        "terraform_module", "tf_state_backend", "ci_cd_pipeline"
      ]
    },
    "azure_resource_name": { "type": "string" },
    "service": { "type": "string", "description": "Service id that owns/uses this resource" },
    "references": {
      "type": ["string", "null"],
      "description": "Model object id this resource corresponds to (e.g. container id for cosmos_container)"
    },
    "env_var": { "type": ["string", "null"], "description": "Config env var that holds the connection string/key" },
    "keyvault_secret_name": { "type": ["string", "null"] },
    "provision_order": {
      "type": "integer",
      "description": "IaC provisioning order — lower numbers are created first (default 99)",
      "default": 99
    },
    "iac_type": {
      "type": "string",
      "enum": ["resource", "vnet", "private-endpoint", "nsg", "terraform-module", "ci-cd", "dns-zone", "iac-state"],
      "description": "Infrastructure-as-Code category for topology sorting and impact analysis"
    },
    "status": {
      "type": "string",
      "enum": ["provisioned", "planned", "deprovisioned"]
    },
    "notes": { "type": ["string", "null"] }
  }
}
