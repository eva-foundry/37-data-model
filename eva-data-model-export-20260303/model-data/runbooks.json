[
  {
    "id": "rb-001",
    "label": "PR → Build/Test → Evidence Pack",
    "status": "active",
    "plane": "plane-github",
    "category": "build",
    "app_id": "app-eva-da-rebuild",
    "environments": [
      "env-dev",
      "env-stg",
      "env-prod"
    ],
    "triggers": [
      {
        "type": "pr_event",
        "source": "github",
        "filters": {
          "events": [
            "opened",
            "synchronize"
          ]
        }
      }
    ],
    "inputs": [
      {
        "name": "prNumber",
        "type": "integer",
        "required": true
      },
      {
        "name": "workItemId",
        "type": "string",
        "required": false
      }
    ],
    "preconditions": [
      {
        "id": "pc-1",
        "text": "PR targets a protected branch (main or release/*)"
      },
      {
        "id": "pc-2",
        "text": "GitHub App has checks:write and contents:read permissions"
      }
    ],
    "steps": [
      {
        "step_id": "s-10",
        "title": "Run test suite + collect coverage",
        "kind": "action",
        "executor": {
          "type": "agent",
          "agent_id": "agent-gh-ci",
          "skill_id": "skill-run-tests"
        },
        "params": {
          "testCommand": "npm run test:coverage"
        },
        "evidence": [
          {
            "type": "artifact",
            "required": true,
            "name": "test-results.json"
          }
        ],
        "on_failure": {
          "strategy": "stop",
          "create_ticket": {
            "enabled": true,
            "target_plane": "ado",
            "work_item_type": "Bug"
          }
        }
      },
      {
        "step_id": "s-20",
        "title": "Assemble and upload signed evidence pack",
        "kind": "action",
        "executor": {
          "type": "agent",
          "agent_id": "agent-gh-ci",
          "skill_id": "skill-pack-evidence"
        },
        "params": {
          "artifacts": [
            "test-results.json",
            "coverage-report.json"
          ]
        },
        "evidence": [
          {
            "type": "artifact",
            "required": true,
            "name": "evidence-pack.json"
          }
        ],
        "on_failure": {
          "strategy": "stop",
          "create_ticket": {
            "enabled": false
          }
        }
      },
      {
        "step_id": "s-30",
        "title": "Post evidence summary as PR check",
        "kind": "notification",
        "executor": {
          "type": "connector",
          "name": "github",
          "operation": "create_check_run"
        },
        "params": {
          "checkName": "evidence-pack",
          "linkToArtifact": true
        },
        "evidence": [],
        "on_failure": {
          "strategy": "continue",
          "create_ticket": {
            "enabled": false
          }
        }
      }
    ],
    "approval_gates": [],
    "outputs": [
      {
        "name": "evidenceId",
        "type": "string"
      },
      {
        "name": "evidencePackUri",
        "type": "string"
      },
      {
        "name": "sha256",
        "type": "string"
      }
    ],
    "evidence_pack": {
      "required": true,
      "schema_version": "1.0",
      "required_artifacts": [
        "test-results.json",
        "coverage-report.json",
        "evidence-pack.json"
      ],
      "retention_days": 90
    },
    "rbac": {
      "can_run_roles": [
        "admin",
        "maintainer",
        "ci-bot"
      ],
      "can_edit_roles": [
        "admin"
      ],
      "can_approve_roles": [
        "approver"
      ]
    },
    "workflow_compiled": "wf-pr-ci-evidence",
    "notes": "This runbook is the source for wf-pr-ci-evidence. Maps to: .github/workflows/rb-001-pr-ci-evidence.yml",
    "source_file": "model/runbooks.json",
    "is_active": true,
    "created_by": "system:autoload",
    "created_at": "2026-02-22T21:17:49.075906-05:00",
    "modified_by": "system:autoload",
    "modified_at": "2026-02-22T21:17:49.075906-05:00",
    "row_version": 1,
    "layer": "runbooks"
  },
  {
    "id": "rb-002",
    "label": "Promote to DEV — Deploy + Smoke Test + Telemetry Snapshot",
    "status": "active",
    "plane": "plane-azure",
    "category": "deploy",
    "app_id": "app-eva-da-rebuild",
    "environments": [
      "env-dev"
    ],
    "triggers": [
      {
        "type": "pr_merged",
        "source": "github",
        "filters": {
          "target_branch": "main"
        }
      }
    ],
    "inputs": [
      {
        "name": "imageTag",
        "type": "string",
        "required": true
      },
      {
        "name": "evidenceId",
        "type": "string",
        "required": true
      },
      {
        "name": "envId",
        "type": "string",
        "required": true,
        "default": "env-dev"
      }
    ],
    "preconditions": [
      {
        "id": "pc-1",
        "text": "PR evidence pack exists and SHA-256 is recorded (rb-001 completed successfully)."
      },
      {
        "id": "pc-2",
        "text": "Container image is published to registry."
      }
    ],
    "steps": [
      {
        "step_id": "s-10",
        "title": "Deploy container image to DEV",
        "kind": "action",
        "executor": {
          "type": "agent",
          "agent_id": "agent-azure-deploy",
          "skill_id": "skill-deploy-resource"
        },
        "params": {
          "envIdFromInput": true,
          "imageTagFromInput": true,
          "evidenceIdFromInput": true
        },
        "evidence": [
          {
            "type": "artifact",
            "required": true,
            "name": "deploy-log-dev.json"
          }
        ],
        "on_failure": {
          "strategy": "stop",
          "create_ticket": {
            "enabled": true,
            "target_plane": "ado",
            "work_item_type": "Bug"
          }
        }
      },
      {
        "step_id": "s-20",
        "title": "Run smoke test (telemetry window — 5 min post-deploy)",
        "kind": "action",
        "executor": {
          "type": "agent",
          "agent_id": "agent-azure-deploy",
          "skill_id": "skill-query-telemetry"
        },
        "params": {
          "envIdFromInput": true,
          "timeWindowMinutes": 5
        },
        "evidence": [
          {
            "type": "artifact",
            "required": true,
            "name": "smoke-telemetry-dev.json"
          }
        ],
        "on_failure": {
          "strategy": "continue",
          "create_ticket": {
            "enabled": true,
            "target_plane": "ado",
            "work_item_type": "Task"
          }
        }
      },
      {
        "step_id": "s-30",
        "title": "Capture telemetry baseline snapshot (30 min)",
        "kind": "action",
        "executor": {
          "type": "agent",
          "agent_id": "agent-azure-deploy",
          "skill_id": "skill-query-telemetry"
        },
        "params": {
          "envIdFromInput": true,
          "timeWindowMinutes": 30,
          "evidenceIdFromInput": true
        },
        "evidence": [
          {
            "type": "artifact",
            "required": true,
            "name": "telemetry-snapshot-dev.json"
          }
        ],
        "on_failure": {
          "strategy": "continue",
          "create_ticket": {
            "enabled": false
          }
        }
      },
      {
        "step_id": "s-40",
        "title": "Append deployment record to evidence pack",
        "kind": "action",
        "executor": {
          "type": "agent",
          "agent_id": "agent-gh-ci",
          "skill_id": "skill-pack-evidence"
        },
        "params": {
          "artifacts": [
            "deploy-log-dev.json",
            "smoke-telemetry-dev.json",
            "telemetry-snapshot-dev.json"
          ]
        },
        "evidence": [
          {
            "type": "artifact",
            "required": true,
            "name": "evidence-pack-deploy.json"
          }
        ],
        "on_failure": {
          "strategy": "stop",
          "create_ticket": {
            "enabled": false
          }
        }
      }
    ],
    "approval_gates": [],
    "outputs": [
      {
        "name": "deploymentId",
        "type": "string"
      },
      {
        "name": "deploymentUrl",
        "type": "string"
      },
      {
        "name": "evidencePackUri",
        "type": "string"
      }
    ],
    "evidence_pack": {
      "required": true,
      "schema_version": "1.0",
      "required_artifacts": [
        "deploy-log-dev.json",
        "smoke-telemetry-dev.json",
        "evidence-pack-deploy.json"
      ],
      "retention_days": 90
    },
    "rbac": {
      "can_run_roles": [
        "admin",
        "maintainer",
        "ci-bot"
      ],
      "can_edit_roles": [
        "admin"
      ],
      "can_approve_roles": [
        "approver"
      ]
    },
    "workflow_compiled": "wf-promote-dev",
    "notes": "STG and PROD variants require approval_gate step (approval_roles: ['approver','admin']). Maps to: .github/workflows/rb-002-promote-dev.yml",
    "source_file": "model/runbooks.json",
    "is_active": true,
    "created_by": "system:autoload",
    "created_at": "2026-02-22T21:17:49.075906-05:00",
    "modified_by": "system:autoload",
    "modified_at": "2026-02-22T21:17:49.075906-05:00",
    "row_version": 1,
    "layer": "runbooks"
  },
  {
    "id": "rb-003",
    "label": "Azure Alert → Triage → Create/Update ADO Bug → Attach Telemetry Evidence",
    "status": "active",
    "plane": "plane-azure",
    "category": "ops",
    "app_id": "app-eva-da-rebuild",
    "environments": [
      "env-dev",
      "env-stg",
      "env-prod"
    ],
    "triggers": [
      {
        "type": "event",
        "source": "azure_monitor",
        "filters": {
          "severity": [
            "Sev0",
            "Sev1",
            "Sev2"
          ]
        }
      }
    ],
    "inputs": [
      {
        "name": "alertId",
        "type": "string",
        "required": true
      },
      {
        "name": "envId",
        "type": "string",
        "required": true
      }
    ],
    "preconditions": [
      {
        "id": "pc-1",
        "text": "Alert contains correlation dimensions (evidenceId or deploymentId when possible)."
      }
    ],
    "steps": [
      {
        "step_id": "s-10",
        "title": "Collect telemetry window (last 30 min)",
        "kind": "action",
        "executor": {
          "type": "agent",
          "agent_id": "agent-azure-deploy",
          "skill_id": "skill-query-telemetry"
        },
        "params": {
          "envIdFromInput": true,
          "timeWindowMinutes": 30
        },
        "evidence": [
          {
            "type": "artifact",
            "required": true,
            "name": "triage-telemetry.json"
          }
        ],
        "on_failure": {
          "strategy": "continue",
          "create_ticket": {
            "enabled": true,
            "target_plane": "ado",
            "work_item_type": "Task"
          }
        }
      },
      {
        "step_id": "s-20",
        "title": "Create/update ADO Bug with telemetry link",
        "kind": "action",
        "executor": {
          "type": "connector",
          "name": "ado",
          "operation": "upsert_bug"
        },
        "params": {
          "titleFromAlert": true,
          "attachArtifacts": [
            "triage-telemetry.json"
          ]
        },
        "evidence": [
          {
            "type": "log",
            "required": true,
            "name": "ado-upsert-log"
          }
        ],
        "on_failure": {
          "strategy": "stop",
          "create_ticket": {
            "enabled": false
          }
        }
      }
    ],
    "approval_gates": [],
    "outputs": [
      {
        "name": "adoBugId",
        "type": "string"
      }
    ],
    "evidence_pack": {
      "required": false,
      "schema_version": "1.0",
      "required_artifacts": [],
      "retention_days": 90
    },
    "rbac": {
      "can_run_roles": [
        "admin",
        "maintainer"
      ],
      "can_edit_roles": [
        "admin"
      ],
      "can_approve_roles": [
        "approver"
      ]
    },
    "workflow_compiled": null,
    "notes": "Triggered by Azure Monitor action group → Function/Job → ADO API.",
    "source_file": "model/runbooks.json",
    "is_active": true,
    "created_by": "system:autoload",
    "created_at": "2026-02-22T21:17:49.075906-05:00",
    "modified_by": "system:autoload",
    "modified_at": "2026-02-22T21:17:49.075906-05:00",
    "row_version": 1,
    "layer": "runbooks"
  },
  {
    "id": "rb-004",
    "label": "Weekly Status Summary (ADO + GitHub + Azure Evidence)",
    "status": "draft",
    "plane": "plane-ado",
    "category": "scrum",
    "app_id": "app-eva-da-rebuild",
    "environments": [
      "env-dev"
    ],
    "triggers": [
      {
        "type": "schedule",
        "source": "ado",
        "filters": {
          "dayOfWeek": "Friday",
          "time": "15:00",
          "timezone": "America/Montreal"
        }
      }
    ],
    "inputs": [
      {
        "name": "iterationPath",
        "type": "string",
        "required": true
      },
      {
        "name": "areaPath",
        "type": "string",
        "required": true
      }
    ],
    "preconditions": [
      {
        "id": "pc-1",
        "text": "ADO project configured; GitHub repo linked; evidence packs produced on PRs."
      }
    ],
    "steps": [
      {
        "step_id": "s-10",
        "title": "Summarize ADO sprint progress (completed/in-progress/blockers)",
        "kind": "action",
        "executor": {
          "type": "agent",
          "agent_id": "agent-ado-scrum",
          "skill_id": "skill-scrum-draft"
        },
        "params": {
          "include": [
            "completed",
            "in_progress",
            "blocked"
          ]
        },
        "evidence": [
          {
            "type": "artifact",
            "required": true,
            "name": "weekly-status.md"
          }
        ],
        "on_failure": {
          "strategy": "stop",
          "create_ticket": {
            "enabled": true,
            "target_plane": "ado",
            "work_item_type": "Task"
          }
        }
      }
    ],
    "approval_gates": [],
    "outputs": [
      {
        "name": "statusMarkdownUri",
        "type": "string"
      }
    ],
    "evidence_pack": {
      "required": false,
      "schema_version": "1.0",
      "required_artifacts": [],
      "retention_days": 30
    },
    "rbac": {
      "can_run_roles": [
        "admin",
        "maintainer"
      ],
      "can_edit_roles": [
        "admin"
      ],
      "can_approve_roles": [
        "approver"
      ]
    },
    "workflow_compiled": null,
    "notes": "Status: draft — needs ADO + GitHub connection IDs configured. Future: enrich with PR/deploy/evidenceId links.",
